# =============================================================================
# Trading Bot — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Angel One SmartAPI  (https://smartapi.angelbroking.com/)
# -----------------------------------------------------------------------------
ANGEL_ONE_CLIENT_ID=your_client_id_here
ANGEL_ONE_API_KEY=your_api_key_here
# Your Angel One login PIN (4-digit MPIN used to log in to the Angel One app)
ANGEL_ONE_PASSWORD=your_mpin_here
# Base32 TOTP secret shown when you enable 2FA in the Angel One app
ANGEL_ONE_TOTP_SECRET=your_totp_secret_here

# -----------------------------------------------------------------------------
# LLM Providers
# -----------------------------------------------------------------------------

# Google Gemini  (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq  (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# NVIDIA NIM  (https://build.nvidia.com/)
NVIDIA_API_KEY=your_nvidia_api_key_here

# -----------------------------------------------------------------------------
# Search & News APIs
# -----------------------------------------------------------------------------

# Tavily AI Search  (https://app.tavily.com/)
TAVILY_API_KEY=your_tavily_api_key_here

# NewsAPI  (https://newsapi.org/account)
NEWSAPI_API_KEY=your_newsapi_api_key_here

# SerpAPI  (https://serpapi.com/manage-api-key)
SERPAPI_API_KEY=your_serpapi_api_key_here

# -----------------------------------------------------------------------------
# Telegram Bot  (create a bot via @BotFather on Telegram)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your personal or group chat ID (use @userinfobot to find it)
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# -----------------------------------------------------------------------------
# Optional overrides
# -----------------------------------------------------------------------------
# Set to "true" to force paper-trading mode regardless of config.yaml
# PAPER_TRADING=true

# Override the log level (DEBUG | INFO | WARNING | ERROR)
# LOG_LEVEL=DEBUG
